import sys

# Inspect PDF structure
# Just check basic properties - fpdf2 generated

# Read file size and basic info
import os

pdf_path = 'Tim_Chu_CV.pdf'
size = os.path.getsize(pdf_path)
print(f"PDF file: {pdf_path}")
print(f"Size: {size} bytes ({size/1024:.1f} KB)")

# Parse text from PDF
# Use PyMuPDF (fitz) if available, else try pdfminer
import importlib

# Try PyMuPDF first
try:
    import fitz
    doc = fitz.open(pdf_path)
    print(f"Number of pages: {doc.page_count}")
    for i, page in enumerate(doc):
        text = page.get_text()
        print(f"\n=== Page {i+1} ===")
        print(text[:500])
    doc.close()
    
    if doc.page_count > 0:
        sys.exit(0)
    else:
        print("ERROR: PDF has no pages")
        sys.exit(1)
except ImportError:
    print("PyMuPDF not available, trying pdfminer...")
    try:
        from pdfminer.high_level import extract_text
        text = extract_text(pdf_path)
        print(text[:500])
        if text:
            sys.exit(0)
        else:
            print("ERROR: No text extracted")
            sys.exit(1)
    except ImportError:
        print("WARNING: No PDF text extractor available")
        sys.exit(0)